@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.PatientMovement>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "My Movement Requests";
    ViewData["Breadcrumb"] = "<a href='/Porter/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Pending Requests</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Pending Movement Requests</h1>
        <p>@Model.Count() request(s) awaiting your action</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]</div>
}

<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px; color:var(--gray-400);">
            <i class="fa-solid fa-clipboard-check" style="font-size:2.5rem; margin-bottom:12px; display:block; color:var(--gray-200);"></i>
            <div style="font-weight:600; color:var(--navy);">No pending requests</div>
            <div style="font-size:.82rem;">You're all caught up.</div>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Current Location</th>
                        <th>Destination</th>
                        <th>Notes</th>
                        <th style="text-align:right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:32px; height:32px; border-radius:50%; background:var(--teal); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.8rem; font-weight:700;">
                                        @(m.Admission?.Patient.FirstName?[0])@(m.Admission?.Patient.LastName?[0])
                                    </div>
                                    <span style="font-weight:600; color:var(--navy);">@m.Admission?.Patient.FullName</span>
                                </div>
                            </td>
                            <td>@(m.Admission?.Bed?.BedNumberWithWard ?? "—")</td>
                            <td><span class="badge badge-gold">@m.Location</span></td>
                            <td>@(m.Notes ?? "—")</td>
                            <td style="text-align:right;">
                                <form asp-action="ConfirmCheckOut" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="movementId" value="@m.Id" />
                                    <button type="submit" class="btn btn-success btn-sm"
                                            onclick="return confirm('Confirm that you have moved this patient to @m.Location?')">
                                        <i class="fa-solid fa-check"></i> Confirm Move
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>