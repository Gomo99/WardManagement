@model WARDMANAGEMENTSYSTEM.ViewModel.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["GuestLayout"] = true;
}

<div class="guest-card">
    <div class="guest-card-header">
        <div class="guest-logo">
            <div class="guest-logo-icon"><i class="fa-solid fa-key"></i></div>
            <div class="guest-logo-text">
                <strong>New Password</strong>
                <span>NMB Ward Management System</span>
            </div>
        </div>
        <p class="guest-subtitle">Create a strong new password for your account</p>
    </div>

    <div class="guest-card-body">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="form-group">
                <label class="form-label" asp-for="Password">New Password <span class="required">*</span></label>
                <div class="input-group">
                    <i class="input-icon fa-solid fa-lock"></i>
                    <input asp-for="Password" class="form-control" type="password"
                           placeholder="••••••••" id="new-password" />
                    <button type="button" class="input-suffix" data-toggle-pw>
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="ConfirmPassword">Confirm Password <span class="required">*</span></label>
                <div class="input-group">
                    <i class="input-icon fa-solid fa-lock"></i>
                    <input asp-for="ConfirmPassword" class="form-control" type="password"
                           placeholder="••••••••" id="confirm-password" />
                    <button type="button" class="input-suffix" data-toggle-pw>
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <!-- Password strength rules -->
            <div style="background:var(--gray-100); border-radius:8px; padding:14px; margin-bottom:20px; font-size:.8rem;">
                <div style="font-weight:600; color:var(--gray-700); margin-bottom:10px;">Password Requirements:</div>
                <div class="pw-rule" id="rule-len"><i class="fa-solid fa-circle-xmark" style="color:var(--danger); margin-right:6px;"></i>At least 8 characters</div>
                <div class="pw-rule" id="rule-upper"><i class="fa-solid fa-circle-xmark" style="color:var(--danger); margin-right:6px;"></i>One uppercase letter</div>
                <div class="pw-rule" id="rule-digit"><i class="fa-solid fa-circle-xmark" style="color:var(--danger); margin-right:6px;"></i>One number</div>
                <div class="pw-rule" id="rule-special"><i class="fa-solid fa-circle-xmark" style="color:var(--danger); margin-right:6px;"></i>One special character (!@@#$...)</div>
            </div>

            <button type="submit" class="btn btn-primary btn-full">
                <i class="fa-solid fa-shield-check"></i> Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const pw = document.getElementById('new-password');
        const rules = {
            'rule-len':     v => v.length >= 8,
            'rule-upper':   v => /[A-Z]/.test(v),
            'rule-digit':   v => /\d/.test(v),
            'rule-special': v => /[^a-zA-Z0-9\s]/.test(v)
        };
        pw.addEventListener('input', () => {
            const v = pw.value;
            for (const [id, fn] of Object.entries(rules)) {
                const el = document.getElementById(id);
                const pass = fn(v);
                el.querySelector('i').className = pass
                    ? 'fa-solid fa-circle-check'
                    : 'fa-solid fa-circle-xmark';
                el.querySelector('i').style.color = pass ? 'var(--success)' : 'var(--danger)';
            }
        });
    </script>
}
