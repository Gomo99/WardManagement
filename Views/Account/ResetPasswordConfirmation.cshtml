@{
    ViewData["Title"] = "Password Reset Successful";
    ViewData["GuestLayout"] = true;
}

<div class="guest-card">
    <div class="guest-card-header">
        <div class="guest-logo">
            <div class="guest-logo-icon"><i class="fa-solid fa-circle-check"></i></div>
            <div class="guest-logo-text">
                <strong>Password Reset</strong>
                <span>NMB Ward Management System</span>
            </div>
        </div>
    </div>

    <div class="guest-card-body" style="text-align:center;">
        <div style="width:72px; height:72px; border-radius:50%; background:#EDFBF3; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:1.8rem; color:var(--success);">
            <i class="fa-solid fa-shield-check"></i>
        </div>
        <h2 style="font-family:var(--font-serif); font-size:1.4rem; color:var(--navy); margin-bottom:12px;">Password Reset Successfully</h2>
        <p style="font-size:.875rem; color:var(--gray-400); line-height:1.6; margin-bottom:28px;">
            Your password has been updated. You can now log in with your new credentials.
        </p>
        <a asp-action="Login" class="btn btn-primary btn-full btn-lg">
            <i class="fa-solid fa-right-to-bracket"></i> Sign In Now
        </a>
    </div>
</div>
