@model WARDMANAGEMENTSYSTEM.ViewModel.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["Breadcrumb"] = "<span class='page-title-bar'>Change Password</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Change Password</h1>
        <p>Update your account password</p>
    </div>
</div>

<div style="max-width:520px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-key" style="color:var(--teal); margin-right:8px;"></i>Password Update</span>
        </div>
        <div class="card-body">
            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label" asp-for="CurrentPassword">Current Password <span class="required">*</span></label>
                    <div class="input-group">
                        <i class="input-icon fa-solid fa-lock"></i>
                        <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="••••••••" />
                        <button type="button" class="input-suffix" data-toggle-pw>
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
                </div>

                <hr class="divider" />

                <div class="form-group">
                    <label class="form-label" asp-for="NewPassword">New Password <span class="required">*</span></label>
                    <div class="input-group">
                        <i class="input-icon fa-solid fa-lock"></i>
                        <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" id="new-pw" />
                        <button type="button" class="input-suffix" data-toggle-pw>
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="ConfirmNewPassword">Confirm New Password <span class="required">*</span></label>
                    <div class="input-group">
                        <i class="input-icon fa-solid fa-lock"></i>
                        <input asp-for="ConfirmNewPassword" class="form-control" type="password" placeholder="••••••••" />
                        <button type="button" class="input-suffix" data-toggle-pw>
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="field-validation-error"></span>
                </div>

                <!-- Strength indicator -->
                <div style="margin-bottom:20px;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
                        <span style="font-size:.78rem; color:var(--gray-400);">Password Strength</span>
                        <span id="strength-label" style="font-size:.78rem; font-weight:600;"></span>
                    </div>
                    <div style="height:5px; background:var(--gray-200); border-radius:4px; overflow:hidden;">
                        <div id="strength-bar" style="height:100%; width:0; border-radius:4px; transition:all .3s;"></div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-shield-check"></i> Update Password
                </button>
                <a asp-action="EditProfile" class="btn btn-outline" style="margin-left:8px;">Cancel</a>
            </form>
        </div>
    </div>

    <div class="alert alert-info" style="margin-top:20px;">
        <i class="fa-solid fa-circle-info"></i>
        Your password must be at least 8 characters and contain an uppercase letter, a number, and a special character.
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const pw = document.getElementById('new-pw');
        const bar = document.getElementById('strength-bar');
        const lbl = document.getElementById('strength-label');
        const colors = ['#C0392B','#E67E22','#F1C40F','#27AE60','#1A7A4A'];
        const labels = ['Very Weak','Weak','Fair','Strong','Very Strong'];

        pw.addEventListener('input', () => {
            const v = pw.value;
            let score = 0;
            if (v.length >= 8) score++;
            if (v.length >= 12) score++;
            if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
            if (/\d/.test(v)) score++;
            if (/[^a-zA-Z0-9\s]/.test(v)) score++;
            score = Math.min(score, 4);
            bar.style.width = ((score + 1) * 20) + '%';
            bar.style.background = colors[score];
            lbl.textContent = labels[score];
            lbl.style.color = colors[score];
        });
    </script>
}
