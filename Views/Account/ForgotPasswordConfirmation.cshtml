@{
    ViewData["Title"] = "Check Your Email";
    ViewData["GuestLayout"] = true;
}

<div class="guest-card">
    <div class="guest-card-header">
        <div class="guest-logo">
            <div class="guest-logo-icon"><i class="fa-solid fa-envelope-open-text"></i></div>
            <div class="guest-logo-text">
                <strong>Email Sent</strong>
                <span>NMB Ward Management System</span>
            </div>
        </div>
    </div>

    <div class="guest-card-body" style="text-align:center;">
        <div style="width:72px; height:72px; border-radius:50%; background:var(--teal-lt); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:1.8rem; color:var(--teal);">
            <i class="fa-solid fa-inbox"></i>
        </div>
        <h2 style="font-family:var(--font-serif); font-size:1.4rem; color:var(--navy); margin-bottom:12px;">Check Your Inbox</h2>
        <p style="font-size:.875rem; color:var(--gray-400); line-height:1.6; margin-bottom:24px;">
            If an account exists with that email address, we've sent a password reset link. The link will expire in <strong>1 hour</strong>.
        </p>

        <div class="alert alert-info" style="text-align:left;">
            <i class="fa-solid fa-circle-info"></i>
            Don't see the email? Check your spam or junk folder.
        </div>

        <div style="margin-top:24px; display:flex; flex-direction:column; gap:10px;">
            <a asp-action="ForgotPassword" class="btn btn-outline btn-full">
                <i class="fa-solid fa-rotate-left"></i> Try Again
            </a>
            <a asp-action="Login" class="btn btn-navy btn-full">
                <i class="fa-solid fa-arrow-left"></i> Back to Login
            </a>
        </div>
    </div>
</div>
