@model WARDMANAGEMENTSYSTEM.ViewModel.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["GuestLayout"] = true;
}

<div class="guest-card">
    <div class="guest-card-header">
        <div class="guest-logo">
            <div class="guest-logo-icon"><i class="fa-solid fa-envelope-circle-check"></i></div>
            <div class="guest-logo-text">
                <strong>Password Reset</strong>
                <span>NMB Ward Management System</span>
            </div>
        </div>
        <p class="guest-subtitle">Enter your email to receive a reset link</p>
    </div>

    <div class="guest-card-body">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" asp-for="Email">Email Address <span class="required">*</span></label>
                <div class="input-group">
                    <i class="input-icon fa-solid fa-envelope"></i>
                    <input asp-for="Email" class="form-control" type="email"
                           placeholder="you@hospital.co.za" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full">
                <i class="fa-solid fa-paper-plane"></i> Send Reset Link
            </button>
        </form>

        <div style="text-align:center; margin-top:20px;">
            <a asp-action="Login" style="font-size:.82rem; color:var(--gray-400); text-decoration:none;">
                <i class="fa-solid fa-arrow-left"></i> Back to Login
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
