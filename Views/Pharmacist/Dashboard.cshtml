@{
    ViewData["Title"] = "Pharmacist Dashboard";
    ViewData["Breadcrumb"] = "<span class='page-title-bar'>Dashboard</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Pharmacy Dashboard</h1>
        <p>Prescription dispensing and medication management</p>
    </div>
    <div>
        <span style="font-size:.8rem; color:var(--gray-400);">
            <i class="fa-regular fa-clock"></i> @DateTime.Now.ToString("dddd, dd MMMM yyyy")
        </span>
    </div>
</div>

<div class="stat-grid" style="margin-bottom:32px;">
    <div class="stat-card">
        <div class="stat-icon gold"><i class="fa-solid fa-prescription"></i></div>
        <div>
            <div class="stat-value">@ViewBag.PendingDispensing</div>
            <div class="stat-label">Pending Dispensing</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-capsules"></i></div>
        <div>
            <div class="stat-value">@ViewBag.DispensedToday</div>
            <div class="stat-label">Dispensed Today</div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-list-check"></i> Prescriptions to Dispense</span></div>
        <div class="card-body">
            <p style="font-size:.82rem; color:var(--gray-400); margin-bottom:16px;">View prescriptions forwarded from the ward and dispense medications.</p>
            <a asp-action="Index" class="btn btn-primary btn-sm"><i class="fa-solid fa-eye"></i> View Prescriptions</a>
        </div>
    </div>
</div>