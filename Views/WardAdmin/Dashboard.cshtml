@{
    ViewData["Title"] = "Ward Admin Dashboard";
    ViewData["Breadcrumb"] = "<span class='page-title-bar'>Dashboard</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Ward Administration</h1>
        <p>Patient admissions, movement, and discharge</p>
    </div>
</div>

<div class="stat-grid" style="margin-bottom:32px;">
    <div class="stat-card">
        <div class="stat-icon teal"><i class="fa-solid fa-bed-pulse"></i></div>
        <div>
            <div class="stat-value">@ViewBag.AdmittedCount</div>
            <div class="stat-label">Currently Admitted</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon gold"><i class="fa-solid fa-person-walking-arrow-right"></i></div>
        <div>
            <div class="stat-value">@ViewBag.OutOfWardCount</div>
            <div class="stat-label">Out of Ward</div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-user-plus"></i> Admit Patient</span></div>
        <div class="card-body">
            <p style="font-size:.82rem; color:var(--gray-400);">Start the admission process — capture personal details and assign a bed.</p>
            <a asp-action="AdmitPatient" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> New Admission</a>
        </div>
    </div>
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-list-check"></i> Current Patients</span></div>
        <div class="card-body">
            <p style="font-size:.82rem; color:var(--gray-400);">View admitted patients, their locations, and manage discharges.</p>
            <a asp-action="Patients" class="btn btn-primary btn-sm"><i class="fa-solid fa-eye"></i> View Patients</a>
        </div>
    </div>
</div>