@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.Admission>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Current Patients";
    ViewData["Breadcrumb"] = "<a href='/WardAdmin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Patients</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Current Patients</h1>
        <p>@Model.Count() active admission(s)</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]</div>
}

<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px;">
            <i class="fa-solid fa-bed-pulse" style="font-size:2.5rem; color:var(--gray-200); margin-bottom:12px; display:block;"></i>
            <div style="font-weight:600; color:var(--navy);">No patients admitted</div>
            <a asp-action="AdmitPatient" class="btn btn-primary btn-sm" style="margin-top:12px;">Admit First Patient</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Bed / Ward</th>
                        <th>Doctor</th>
                        <th>Location</th>
                        <th>Admitted</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var adm in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:32px; height:32px; border-radius:50%; background:var(--teal); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.8rem; font-weight:700;">
                                        @(adm.Patient.FirstName?[0])@(adm.Patient.LastName?[0])
                                    </div>
                                    <span style="font-weight:600; color:var(--navy);">@adm.Patient.FullName</span>
                                </div>
                            </td>
                            <td>@adm.Bed?.BedNumberWithWard</td>
                            <td>@adm.Doctor?.FullName</td>
                            <td>
                                @if (string.IsNullOrEmpty(adm.CurrentLocation))
                                {
                                    <span class="badge badge-success"><span class="badge-dot"></span> In Ward</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><span class="badge-dot"></span> @adm.CurrentLocation</span>
                                }
                            </td>
                            <td>@adm.AdmissionDate.ToString("dd MMM yyyy")</td>
                            <td style="text-align:right;">
                                <a asp-action="Details" asp-route-id="@adm.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-folder-open"></i> Folder</a>
                                <form asp-action="Discharge" asp-route-admissionId="@adm.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger); border-color:var(--danger);"
                                            onclick="return confirm('Discharge this patient?')"><i class="fa-solid fa-right-from-bracket"></i> Discharge</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>