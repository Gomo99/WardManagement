@model WARDMANAGEMENTSYSTEM.Models.Patient
@{
    ViewData["Title"] = "Admit Patient – Step 1";
    ViewData["Breadcrumb"] = "<a href='/WardAdmin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Admit Patient</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Admit Patient</h1>
        <p>Step 1 – Patient Details</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:760px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-address-card"></i> Personal Information</span>
        </div>
        <div class="card-body">
            <form asp-action="AdmitPatient" method="post">
                @Html.AntiForgeryToken()

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label class="form-label" asp-for="FirstName">First Name <span class="required">*</span></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="LastName">Last Name <span class="required">*</span></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="SouthAfricanIdNumber">South African ID Number <span class="required">*</span></label>
                    <input asp-for="SouthAfricanIdNumber" class="form-control" placeholder="13-digit ID number" />
                    <span asp-validation-for="SouthAfricanIdNumber" class="field-validation-error"></span>
                    <small class="form-text text-muted">If the patient already exists, you will be redirected to the next step.</small>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label class="form-label" asp-for="DateOfBirth">Date of Birth <span class="required">*</span></label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" />
                        <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="CellphoneNumber">Cellphone <span class="required">*</span></label>
                        <input asp-for="CellphoneNumber" class="form-control" />
                        <span asp-validation-for="CellphoneNumber" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Email">Email Address <span class="required">*</span></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="HomeAddress">Home Address <span class="required">*</span></label>
                    <textarea asp-for="HomeAddress" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="HomeAddress" class="field-validation-error"></span>
                </div>

                <div style="display:flex; gap:12px; margin-top:8px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-arrow-right"></i> Next Step</button>
                    <a asp-action="Dashboard" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }