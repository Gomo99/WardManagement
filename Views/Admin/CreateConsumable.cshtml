@model WARDMANAGEMENTSYSTEM.Models.Consumable
@{
    ViewData["Title"] = "Add Consumable";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Admin/Consumables'>Consumables</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Add New</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Add Consumable</h1>
        <p>Register a new stock item for the ward</p>
    </div>
    <a asp-action="Consumables" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-box-open" style="color:var(--teal); margin-right:8px;"></i>Consumable Details</span>
        </div>
        <div class="card-body">
            <form asp-action="CreateConsumable" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" asp-for="Name">Name <span class="required">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Sterile Gloves" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional description"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label class="form-label" asp-for="QuantityOnHand">Quantity On Hand</label>
                        <input asp-for="QuantityOnHand" class="form-control" type="number" value="0" />
                        <span asp-validation-for="QuantityOnHand" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="ReorderLevel">Reorder Level</label>
                        <input asp-for="ReorderLevel" class="form-control" type="number" value="5" />
                        <span asp-validation-for="ReorderLevel" class="field-validation-error"></span>
                    </div>
                </div>
                <div style="display:flex; gap:12px; margin-top:4px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Create Consumable</button>
                    <a asp-action="Consumables" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}