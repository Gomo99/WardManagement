@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.Allergy>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Allergies";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Allergies</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Allergies</h1>
        <p>@Model.Count() allergy(s) recorded</p>
    </div>
    <a asp-action="CreateAllergy" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Add Allergy
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<!-- STATUS FILTER -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-body" style="padding:14px 20px;">
        <form method="get" asp-action="Allergies" style="display:flex; gap:10px; align-items:flex-end;">
            <div>
                <label class="form-label" style="margin-bottom:5px;">Status</label>
                <select name="status" asp-items="ViewBag.Statuses" class="form-control" style="width:130px;"></select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-filter"></i> Apply</button>
            <a asp-action="Allergies" class="btn btn-outline btn-sm"><i class="fa-solid fa-xmark"></i> Clear</a>
        </form>
    </div>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px; color:var(--gray-400);">
            <i class="fa-solid fa-triangle-exclamation" style="font-size:2.5rem; margin-bottom:12px; display:block; color:var(--gray-200);"></i>
            <div style="font-weight:600; color:var(--navy); margin-bottom:4px;">No allergies found</div>
            <a asp-action="CreateAllergy" class="btn btn-primary btn-sm" style="margin-top:12px;">Add First Allergy</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var allergy in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:32px; height:32px; border-radius:8px; background:#FDF0EE; color:var(--danger); display:flex; align-items:center; justify-content:center; font-size:.85rem;">
                                        <i class="fa-solid fa-triangle-exclamation"></i>
                                    </div>
                                    <span style="font-weight:600; color:var(--navy);">@allergy.Name</span>
                                </div>
                            </td>
                            <td>
                                @if (allergy.IsActive == Status.Active)
                                {
                                    <span class="badge badge-success"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex; gap:6px; justify-content:flex-end;">
                                    <a asp-action="DetailsAllergy" asp-route-id="@allergy.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="EditAllergy" asp-route-id="@allergy.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i></a>
                                    @if (allergy.IsActive == Status.Active)
                                    {
                                        <form asp-action="DeleteAllergy" asp-route-id="@allergy.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger); border-color:var(--danger);"
                                                    onclick="return confirm('Deactivate @allergy.Name?')">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="RestoreAllergy" asp-route-id="@allergy.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--success); border-color:var(--success);">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>