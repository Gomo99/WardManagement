@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.Medication>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Medications";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Medications</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Medications</h1>
        <p>@Model.Count() medication(s) in formulary</p>
    </div>
    <a asp-action="CreateMedication" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Add Medication
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<!-- STATUS FILTER -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-body" style="padding:14px 20px;">
        <form method="get" asp-action="Medications" style="display:flex; gap:10px; align-items:flex-end;">
            <div>
                <label class="form-label" style="margin-bottom:5px;">Status</label>
                <select name="status" asp-items="ViewBag.Statuses" class="form-control" style="width:130px;"></select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-filter"></i> Apply</button>
            <a asp-action="Medications" class="btn btn-outline btn-sm"><i class="fa-solid fa-xmark"></i> Clear</a>
        </form>
    </div>
</div>


<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px; color:var(--gray-400);">
            <i class="fa-solid fa-pills" style="font-size:2.5rem; margin-bottom:12px; display:block; color:var(--gray-200);"></i>
            <div style="font-weight:600; color:var(--navy); margin-bottom:4px;">No medications found</div>
            <a asp-action="CreateMedication" class="btn btn-primary btn-sm" style="margin-top:12px;">Add First Medication</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Dosage Form</th>
                        <th>Schedule</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var med in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:32px; height:32px; border-radius:8px; background:#EDFBF3; color:var(--success); display:flex; align-items:center; justify-content:center; font-size:.85rem;">
                                        <i class="fa-solid fa-pills"></i>
                                    </div>
                                    <span style="font-weight:600; color:var(--navy);">@med.Name</span>
                                </div>
                            </td>
                            <td>@(string.IsNullOrEmpty(med.DosageForm) ? "—" : med.DosageForm)</td>
                            <td>@(med.Schedule.HasValue? med.Schedule.ToString() : "Non‑scheduled")</td>
                            <td>
                                @if (med.IsActive == Status.Active)
                                {
                                    <span class="badge badge-success"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex; gap:6px; justify-content:flex-end;">
                                    <a asp-action="DetailsMedication" asp-route-id="@med.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="EditMedication" asp-route-id="@med.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i></a>
                                    @if (med.IsActive == Status.Active)
                                    {
                                        <form asp-action="DeleteMedication" asp-route-id="@med.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger); border-color:var(--danger);"
                                                    onclick="return confirm('Deactivate @med.Name?')">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="RestoreMedication" asp-route-id="@med.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--success); border-color:var(--success);">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>