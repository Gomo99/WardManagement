@model WARDMANAGEMENTSYSTEM.Models.HospitalInfo
@{
    ViewData["Title"] = "Edit Hospital Information";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Admin/HospitalInfo'>Hospital Info</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Edit Hospital Information</h1>
        <p>Update business details</p>
    </div>
    <a asp-action="HospitalInfo" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-hospital" style="color:var(--navy); margin-right:8px;"></i>Edit Details</span>
        </div>
        <div class="card-body">
            <form asp-action="EditHospitalInfo" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="IsActive" type="hidden" />

                <div class="form-group">
                    <label class="form-label" asp-for="HospitalName">Hospital Name <span class="required">*</span></label>
                    <input asp-for="HospitalName" class="form-control" />
                    <span asp-validation-for="HospitalName" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Address">Address</label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label class="form-label" asp-for="ContactNumber">Contact Number</label>
                        <input asp-for="ContactNumber" class="form-control" />
                        <span asp-validation-for="ContactNumber" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Email">Email</label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>
                </div>

                <div style="display:flex; gap:12px; margin-top:4px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
                    <a asp-action="HospitalInfo" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}