@model WARDMANAGEMENTSYSTEM.Models.Allergy
@{
    ViewData["Title"] = "Add Allergy";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Admin/Allergies'>Allergies</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Add New</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Add Allergy</h1>
        <p>Create a new allergy reference</p>
    </div>
    <a asp-action="Allergies" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--danger); margin-right:8px;"></i>Allergy Details</span>
        </div>
        <div class="card-body">
            <form asp-action="CreateAllergy" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" asp-for="Name">Name <span class="required">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Penicillin" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional description"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>
                <div style="display:flex; gap:12px; margin-top:4px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Create Allergy</button>
                    <a asp-action="Allergies" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}