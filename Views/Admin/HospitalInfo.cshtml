@model WARDMANAGEMENTSYSTEM.Models.HospitalInfo
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Hospital Information";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Hospital Info</span>";
    var isActive = Model.IsActive == Status.Active;
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Hospital Information</h1>
        <p>Manage business details of the hospital</p>
    </div>
    <a asp-action="EditHospitalInfo" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-pen"></i> Edit
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<div style="max-width:560px;">
    <div class="card">
        <div class="card-body">
            <div style="display:flex; align-items:center; gap:16px; margin-bottom:20px;">
                <div style="width:52px; height:52px; border-radius:12px; background:#E8EEF5; color:var(--navy); display:flex; align-items:center; justify-content:center; font-size:1.3rem;">
                    <i class="fa-solid fa-hospital"></i>
                </div>
                <div>
                    <h2 style="font-family:var(--font-serif); font-size:1.3rem; color:var(--navy); margin-bottom:4px;">@Model.HospitalName</h2>
                    <span class="badge @(isActive ? "badge-success" : "badge-danger")">
                        <span class="badge-dot"></span> @Model.IsActive
                    </span>
                </div>
            </div>

            <div style="background:var(--gray-50); border-radius:8px; padding:14px; font-size:.875rem;">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div>
                        <div style="font-size:.72rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px;">Address</div>
                        <div style="font-weight:500; color:var(--navy);">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</div>
                    </div>
                    <div>
                        <div style="font-size:.72rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px;">Contact Number</div>
                        <div style="font-weight:500; color:var(--navy);">@(string.IsNullOrEmpty(Model.ContactNumber) ? "—" : Model.ContactNumber)</div>
                    </div>
                    <div style="grid-column:1/-1;">
                        <div style="font-size:.72rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px;">Email</div>
                        <div style="font-weight:500; color:var(--navy);">@(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="border-color:@(isActive ? "#F5C6C1" : "#A7E8C8");">
        <div class="card-body" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
            <div>
                <div style="font-weight:600; color:var(--gray-700); margin-bottom:2px;">Status: @Model.IsActive</div>
            </div>
            @if (isActive)
            {
                <form asp-action="DeleteHospitalInfo" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Deactivate this info?')">
                        <i class="fa-solid fa-ban"></i> Deactivate
                    </button>
                </form>
            }
            else
            {
                <form asp-action="RestoreHospitalInfo" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm" style="background:var(--success); color:#fff;">
                        <i class="fa-solid fa-rotate-left"></i> Reactivate
                    </button>
                </form>
            }
        </div>
    </div>
</div>