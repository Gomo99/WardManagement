@model WARDMANAGEMENTSYSTEM.Models.Ward
@{
    ViewData["Title"] = "Edit Ward";
    ViewData["Breadcrumb"] = "<a href='/Admin/Wards'>Wards</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Edit Ward</h1><p>@Model.Name</p></div>
    <a asp-action="Wards" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>
<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-hospital" style="color:var(--teal); margin-right:8px;"></i>Edit Ward Details</span>
        </div>
        <div class="card-body">
            <form asp-action="EditWard" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="IsActive" type="hidden" />
                <div class="form-group">
                    <label class="form-label" asp-for="Name">Ward Name <span class="required">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    <a asp-action="Wards" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
