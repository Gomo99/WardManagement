@model WARDMANAGEMENTSYSTEM.Models.Medication
@{
    ViewData["Title"] = "Edit Medication";
    ViewData["Breadcrumb"] = "<a href='/Admin/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Admin/Medications'>Medications</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Edit Medication</h1>
        <p>@Model.Name</p>
    </div>
    <a asp-action="Medications" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-pills" style="color:var(--success); margin-right:8px;"></i>Edit Medication</span>
        </div>
        <div class="card-body">
            <form asp-action="EditMedication" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="IsActive" type="hidden" />
                <div class="form-group">
                    <label class="form-label" asp-for="Name">Name <span class="required">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="DosageForm">Dosage Form</label>
                    <input asp-for="DosageForm" class="form-control" />
                    <span asp-validation-for="DosageForm" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label>Allergies treated (hold Ctrl to select multiple)</label>
                    <select name="allergyIds" class="form-control" multiple>
                        @if (ViewBag.Allergies is SelectList allergies)
                        {
                            var selected = ViewBag.SelectedAllergyIds as List<int> ?? new List<int>();
                            foreach (var item in allergies)
                            {
                                var allergyId = Convert.ToInt32(item.Value);
                                <option value="@item.Value" selected="@(selected.Contains(allergyId) ? "selected" : null)">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                <!-- Conditions multi-select -->
                <div class="form-group">
                    <label>Conditions treated</label>
                    <select name="conditionIds" class="form-control" multiple>
                        @if (ViewBag.Conditions is SelectList conditions)
                        {
                            var selected = ViewBag.SelectedConditionIds as List<int> ?? new List<int>();
                            foreach (var item in conditions)
                            {
                                var conditionId = Convert.ToInt32(item.Value);
                                <option value="@item.Value" selected="@(selected.Contains(conditionId) ? "selected" : null)">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Schedule">Schedule</label>
                    <input asp-for="Schedule" class="form-control" type="number" min="0" max="8" placeholder="Leave blank for non‑scheduled" />
                    <span asp-validation-for="Schedule" class="field-validation-error"></span>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    <a asp-action="Medications" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}