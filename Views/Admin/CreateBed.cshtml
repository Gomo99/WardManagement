@model WARDMANAGEMENTSYSTEM.Models.Bed
@{
    ViewData["Title"] = "Add Bed";
    ViewData["Breadcrumb"] = "<a href='/Admin/Beds'>Beds</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Add New</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Add Bed</h1><p>Create a new bed in a ward</p></div>
    <a asp-action="Beds" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>
<div style="max-width:480px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-bed" style="color:var(--teal); margin-right:8px;"></i>Bed Details</span>
        </div>
        <div class="card-body">
            <form asp-action="CreateBed" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" asp-for="WardId">Ward <span class="required">*</span></label>
                    <select asp-for="WardId" asp-items="ViewBag.Wards" class="form-control">
                        <option value="">Select ward</option>
                    </select>
                    <span asp-validation-for="WardId" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="BedNumber">Bed Number <span class="required">*</span></label>
                    <input asp-for="BedNumber" class="form-control" placeholder="e.g. A-01" />
                    <span asp-validation-for="BedNumber" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-check">
                        <input asp-for="IsOccupied" type="checkbox" class="form-check-input" />
                        <span class="form-check-label">Mark as occupied</span>
                    </label>
                </div>
                <div style="display:flex; gap:12px; margin-top:4px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Create Bed</button>
                    <a asp-action="Beds" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
