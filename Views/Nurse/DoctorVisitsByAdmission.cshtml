@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.DoctorVisit>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Doctor Visits";
    ViewData["Breadcrumb"] = "<a href='/Nurse/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Nurse/Patients'>Patients</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Doctor Visits</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Doctor Visits</h1><p>@ViewBag.PatientName</p></div>
    <div style="display:flex; gap:8px;">
        <a asp-action="RecordDoctorContact" asp-route-admissionId="@ViewBag.AdmissionId" class="btn btn-primary btn-sm"><i class="fa-solid fa-phone"></i> Record Contact</a>
        <a asp-action="Patients" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
    </div>
</div>



<div class="card">
    @if (!Model.Any())
    {
        <div style="padding:40px; text-align:center;">No visits recorded.</div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Doctor</th>
                        <th>Instructions</th>
                        <th>Type</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dv in Model)
                    {
                        <tr>
                            <td>@dv.VisitDate.ToString("g")</td>
                            <td>@(dv.Doctor?.FullName ?? dv.ExternalDoctorName ?? "—")</td>
                            <td>@dv.Instructions</td>
                            <td>@(dv.IsContactRecord ? "Phone Contact" : "Visit")</td>
                            <td style="text-align:right;">
                                <a asp-action="DoctorVisitDetails" asp-route-id="@dv.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-eye"></i></a>
                                <a asp-action="EditDoctorVisit" asp-route-id="@dv.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="DeleteDoctorVisit" asp-route-id="@dv.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger);" onclick="return confirm('Deactivate this visit?')"><i class="fa-solid fa-ban"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>