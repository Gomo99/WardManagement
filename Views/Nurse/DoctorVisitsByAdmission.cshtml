@model List<DoctorVisit>
@{
    ViewData["Title"] = "Doctor Visits";
    ViewData["Breadcrumb"] = $"<span class='page-title-bar'>Doctor Visits for {ViewBag.PatientName}</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1><i class="fa-solid fa-user-doctor"></i> Doctor Visits & Instructions</h1>
        <p>@ViewBag.PatientName</p>
    </div>
    <a asp-action="Patients" class="btn btn-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Back to Patients</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Date</th>
            <th>Doctor</th>
            <th>Instructions</th>
            <th>Status</th>
            <th>Acknowledged By</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var visit in Model)
        {
            <tr>
                <td>@visit.VisitDate.ToString("dd MMM HH:mm")</td>
                <td>@(visit.Doctor?.FullName ?? visit.ExternalDoctorName ?? "—")</td>
                <td>@(string.IsNullOrWhiteSpace(visit.Instructions) ? "—" : visit.Instructions)</td>
                <td>
                    @if (visit.InstructionStatus == "Completed")
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else if (visit.InstructionStatus == "Seen")
                    {
                        <span class="badge bg-info">Seen</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">New</span>
                    }
                </td>
                <td>
                    @if (visit.AcknowledgedBy != null)
                    {
                        <span>@visit.AcknowledgedBy.FullName</span>
                        <br />

                        <small>@visit.AcknowledgedAt?.ToString("HH:mm")</small>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(visit.Instructions))
                    {
                        @if (visit.InstructionStatus != "Completed")
                        {
                            @if (visit.InstructionStatus != "Seen")
                            {
                                <form asp-action="AcknowledgeSeen" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="visitId" value="@visit.Id" />
                                    <button type="submit" class="btn btn-outline-info btn-sm"><i class="fa-solid fa-eye"></i> Seen</button>
                                </form>
                            }
                            <form asp-action="CompleteInstruction" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="visitId" value="@visit.Id" />
                                <button type="submit" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-check"></i> Complete</button>
                            </form>
                        }
                    }
                    <a asp-action="DoctorVisitDetails" asp-route-id="@visit.Id" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-circle-info"></i></a>
                </td>
            </tr>
        }
    </tbody>
</table>