@model WARDMANAGEMENTSYSTEM.Models.DoctorVisit
@{
    ViewData["Title"] = "Record Doctor Contact";
    ViewData["Breadcrumb"] = "<a href='/Nurse/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Nurse/Patients'>Patients</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Record Contact</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Record Doctor Contact</h1><p>@ViewBag.PatientName</p></div>
    <a asp-action="DoctorVisitsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>
<div style="max-width:560px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-phone"></i> Phone / Contact Details</span></div>
        <div class="card-body">
            <form asp-action="RecordDoctorContact" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="AdmissionId" type="hidden" />
                <input asp-for="IsContactRecord" type="hidden" value="true" />
                <div class="form-group">
                    <label class="form-label" asp-for="DoctorId">Doctor (if internal)</label>
                    <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-control">
                        <option value="">Select doctor...</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ExternalDoctorName">Or External Doctor Name</label>
                    <input asp-for="ExternalDoctorName" class="form-control" placeholder="e.g. Dr. Smith" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="VisitDate">Date &amp; Time</label>
                    <input asp-for="VisitDate" class="form-control" type="datetime-local" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Instructions">Instructions Received</label>
                    <textarea asp-for="Instructions" class="form-control" rows="3" placeholder="Doctor's instructions..."></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <small class="text-muted">Either select an internal doctor or enter an external name.</small>
                <div style="display:flex; gap:12px; margin-top:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save Contact</button>
                    <a asp-action="DoctorVisitsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}