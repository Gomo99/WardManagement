@model WARDMANAGEMENTSYSTEM.Models.DoctorVisit
@{
    ViewData["Title"] = "Edit Doctor Visit";
    ViewData["Breadcrumb"] = "<a href='/Nurse/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit Visit</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Edit Doctor Visit</h1><p>@ViewBag.PatientName</p></div>
    <a asp-action="DoctorVisitsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>
<div style="max-width:560px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-pen-to-square"></i> Edit Visit</span></div>
        <div class="card-body">
            <form asp-action="EditDoctorVisit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="AdmissionId" type="hidden" />
                <div class="form-group">
                    <label class="form-label" asp-for="DoctorId">Doctor (internal)</label>
                    <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-control">
                        <option value="">Select...</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ExternalDoctorName">Or External Name</label>
                    <input asp-for="ExternalDoctorName" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="VisitDate">Date</label>
                    <input asp-for="VisitDate" class="form-control" type="datetime-local" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Instructions">Instructions</label>
                    <textarea asp-for="Instructions" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    <a asp-action="DoctorVisitsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }