@model List<Prescription>
@{
    ViewData["Title"] = "Delayed Deliveries";
    ViewData["Breadcrumb"] = "<a href='/ScriptManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Delayed Deliveries</span>";
}
<div class="page-header">
    <h1><i class="fa-solid fa-clock"></i> Delayed Deliveries (> @ViewBag.Days days)</h1>
    <a asp-action="Dashboard" class="btn btn-secondary btn-sm">Back</a>
</div>
<form method="get" asp-action="DelayedDeliveries" class="row g-2 mb-3 align-items-end">
    <div class="col-auto"><label>Delay (days)</label><input type="number" name="days" class="form-control" value="@ViewBag.Days" style="width:100px;" /></div>
    <div class="col-auto"><button type="submit" class="btn btn-primary btn-sm">Apply</button></div>
</form>
@if (!Model.Any())
{
    <div class="alert alert-success">No delayed deliveries.</div>
}
else
{
    <table class="table">
        <thead><tr><th>Patient</th><th>Medication</th><th>Prescribed</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr><td>@p.Admission?.Patient?.FullName</td><td>@p.Medication?.Name</td><td>@p.PrescribedDate.ToString("dd MMM yyyy")</td><td>@p.ScriptStatus</td></tr>
            }
        </tbody>
    </table>
}