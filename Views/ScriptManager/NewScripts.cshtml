@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.Prescription>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "New Prescriptions";
    ViewData["Breadcrumb"] = "<a href='/ScriptManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>New Scripts</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>New Prescriptions</h1>
        <p>@Model.Count() awaiting processing</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]</div>
}

<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px; color:var(--gray-400);">
            <i class="fa-solid fa-file-prescription" style="font-size:2.5rem; margin-bottom:12px; display:block; color:var(--gray-200);"></i>
            <div style="font-weight:600; color:var(--navy); margin-bottom:4px;">No new prescriptions</div>
            <div style="font-size:.82rem;">All scripts have been processed.</div>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Medication</th>
                        <th>Dosage</th>
                        <th>Prescribed</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var script in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:8px;">
                                    <i class="fa-solid fa-user" style="color:var(--teal);"></i>
                                    <span style="font-weight:600; color:var(--navy);">@script.Admission?.Patient.FullName</span>
                                </div>
                            </td>
                            <td>@script.Medication?.Name</td>
                            <td>@script.Dosage</td>
                            <td>@script.PrescribedDate.ToString("dd MMM yyyy")</td>
                            <td><span class="badge badge-gold">@script.ScriptStatus</span></td>
                            <td style="text-align:right;">
                                <a asp-action="Details" asp-route-id="@script.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@script.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="ForwardToPharmacy" asp-route-id="@script.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline btn-sm" style="color:var(--success); border-color:var(--success);"
                                            onclick="return confirm('Forward this prescription to pharmacy?')">
                                        <i class="fa-solid fa-paper-plane"></i> Forward
                                    </button>
                                </form>
                                <form asp-action="DeleteScript" asp-route-id="@script.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger); border-color:var(--danger);"
                                            onclick="return confirm('Deactivate this prescription?')">
                                        <i class="fa-solid fa-ban"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>