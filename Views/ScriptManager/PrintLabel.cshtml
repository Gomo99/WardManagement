@model Prescription
@{
    Layout = null;
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var detailsUrl = $"{baseUrl}/ScriptManager/Details/{Model.Id}";
    var qrCodeUrl = $"https://chart.googleapis.com/chart?chs=150x150&cht=qr&chl={Uri.EscapeDataString(detailsUrl)}";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Prescription Label #@Model.Id</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 20px;
            color: #333;
        }

        .label {
            border: 2px solid #000;
            padding: 16px;
            max-width: 300px;
            margin: 0 auto;
            text-align: center;
            border-radius: 8px;
        }

        .qr {
            margin: 10px 0;
        }

        h3 {
            margin: 0;
        }

        .info {
            text-align: left;
            margin-top: 10px;
        }

            .info td {
                padding: 2px 6px;
            }

        .no-print {
            margin-top: 20px;
            text-align: center;
        }

        .print-btn {
            background: #2980b9;
            color: white;
            border: none;
            padding: 10px 24px;
            font-size: 16px;
            border-radius: 6px;
            cursor: pointer;
        }

        @@media print {
            .no-print {
                display: none;
            }

            body {
                margin: 0;
            }
        }
    </style>
</head>
<body>

    <div class="label">
        <h3>@Model.Medication?.Name</h3>
        <p>@Model.Dosage – @Model.Frequency</p>
        <div class="qr">
            <img src="@qrCodeUrl" alt="QR Code" width="150" height="150" />
        </div>
        <table class="info">
            <tr><td>Patient:</td><td>@Model.Admission?.Patient?.FullName</td></tr>
            <tr><td>Prescribed:</td><td>@Model.PrescribedDate.ToString("dd MMM yyyy")</td></tr>
            <tr><td>Status:</td><td>@Model.ScriptStatus</td></tr>
            <tr><td>Doctor:</td><td>Dr. @Model.Admission?.Doctor?.FullName</td></tr>
            <tr><td>Ward:</td><td>@Model.Admission?.Bed?.Ward.Name</td></tr>
        </table>
    </div>

    <div class="no-print">
        <button class="print-btn" onclick="window.print()">🖨️ Print Label</button>
        &nbsp;
        <a asp-action="AllScripts" class="print-btn" style="background:#7f8c8d; text-decoration:none;">Back to Scripts</a>
    </div>

</body>
</html>