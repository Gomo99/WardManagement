@model Prescription
@{
    Layout = null;   // no layout – clean, printer‑friendly
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Prescription Label</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 12pt;
            margin: 20px;
        }

        .label-box {
            border: 2px solid #000;
            padding: 20px;
            width: 400px;
            page-break-inside: avoid;
        }

            .label-box h2 {
                margin-top: 0;
                font-size: 16pt;
            }

        .label-row {
            margin-bottom: 6px;
        }

            .label-row strong {
                display: inline-block;
                width: 100px;
            }

        @@media print {
            body {
                margin: 0;
            }

            .label-box {
                border: none;
            }
        }
    </style>
</head>
<body>
    <div class="label-box">
        <h2>Ward Prescription Label</h2>
        <div class="label-row"><strong>Patient:</strong> @Model.Admission?.Patient?.FullName</div>
        <div class="label-row"><strong>Medication:</strong> @Model.Medication?.Name</div>
        <div class="label-row"><strong>Dosage:</strong> @Model.Dosage</div>
        <div class="label-row"><strong>Frequency:</strong> @Model.Frequency</div>
        <div class="label-row"><strong>Duration:</strong> @Model.Duration</div>
        <div class="label-row"><strong>Prescribed:</strong> @Model.PrescribedDate.ToString("dd MMM yyyy HH:mm")</div>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="label-row"><strong>Notes:</strong> @Model.Notes</div>
        }
    </div>
    <script>
        window.onload = function () { window.print(); }
    </script>
</body>
</html>