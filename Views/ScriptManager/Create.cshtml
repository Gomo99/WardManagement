@using WARDMANAGEMENTSYSTEM.AppStatus
@model Prescription
@{
    ViewData["Title"] = "Create Prescription";
    ViewData["Breadcrumb"] = "<a href='/ScriptManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>New Prescription</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1><i class="fa-solid fa-file-prescription"></i> Create Prescription</h1>
        <p>Manual entry</p>
    </div>
    <a asp-action="AllScripts" class="btn btn-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Back to Scripts</a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-pills"></i> Prescription Details</span></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="AdmissionId" class="form-label">Admission</label>
                    <select asp-for="AdmissionId" asp-items="ViewBag.Admissions" class="form-select">
                        <option value="">-- Select Patient / Admission --</option>
                    </select>
                    <span asp-validation-for="AdmissionId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MedicationId" class="form-label">Medication</label>
                    <select asp-for="MedicationId" asp-items="ViewBag.Medications" class="form-select">
                        <option value="">-- Select Medication --</option>
                    </select>
                    <span asp-validation-for="MedicationId" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="Dosage" class="form-label">Dosage</label>
                    <input asp-for="Dosage" class="form-control" placeholder="e.g. 500mg" />
                    <span asp-validation-for="Dosage" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Frequency" class="form-label">Frequency</label>
                    <input asp-for="Frequency" class="form-control" placeholder="e.g. 3x daily" />
                    <span asp-validation-for="Frequency" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Duration" class="form-label">Duration</label>
                    <input asp-for="Duration" class="form-control" placeholder="e.g. 7 days" />
                    <span asp-validation-for="Duration" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="QuantityPrescribed" class="form-label">Quantity</label>
                    <input asp-for="QuantityPrescribed" type="number" class="form-control" min="1" value="1" />
                    <span asp-validation-for="QuantityPrescribed" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes"></textarea>
            </div>

            <!-- Duplicate override -->
            @if (ViewContext.ModelState["MedicationId"]?.Errors.Any(e => e.ErrorMessage.Contains("already has an active prescription")) == true)
            {
                <div class="alert alert-warning">
                    <i class="fa-solid fa-triangle-exclamation"></i> Duplicate prescription detected!
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="confirmDuplicate" value="true" id="confirmDuplicate" />
                        <label class="form-check-label" for="confirmDuplicate">
                            I understand, prescribe anyway
                        </label>
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" name="confirmDuplicate" value="false" />
            }

            <div class="col-md-3 mb-3">
                <label asp-for="Priority" class="form-label">Priority</label>
                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<PrescriptionPriority>()"></select>
            </div>

            <div class="text-end">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Create Prescription</button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}