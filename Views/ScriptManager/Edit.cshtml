@using WARDMANAGEMENTSYSTEM.AppStatus
@model WARDMANAGEMENTSYSTEM.Models.Prescription
@{
    ViewData["Title"] = "Edit Prescription";
    ViewData["Breadcrumb"] = "<a href='/ScriptManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/ScriptManager/AllScripts'>All Scripts</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit</span>";
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Edit Prescription</h1>
        <p>Prescription #@Model.Id — @Model.Admission?.Patient.FullName</p>
    </div>
    <a asp-action="AllScripts" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-pen-to-square"></i> Edit Prescription</span></div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="ScriptStatus" type="hidden" />

                <div class="form-group">
                    <label class="form-label" asp-for="AdmissionId">Patient / Admission</label>
                    <select asp-for="AdmissionId" asp-items="ViewBag.Admissions" class="form-control"></select>
                    <span asp-validation-for="AdmissionId" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="MedicationId">Medication</label>
                    <select asp-for="MedicationId" asp-items="ViewBag.Medications" class="form-control"></select>
                    <span asp-validation-for="MedicationId" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Dosage">Dosage</label>
                    <input asp-for="Dosage" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Frequency">Frequency</label>
                    <input asp-for="Frequency" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Duration">Duration</label>
                    <input asp-for="Duration" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="PrescribedDate">Prescribed Date</label>
                    <input asp-for="PrescribedDate" class="form-control" type="datetime-local" />
                </div>


                <div class="col-md-3 mb-3">
                    <label asp-for="Priority" class="form-label">Priority</label>
                    <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<PrescriptionPriority>()"></select>
                </div>
                <div style="display:flex; gap:12px; margin-top:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    <a asp-action="AllScripts" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}