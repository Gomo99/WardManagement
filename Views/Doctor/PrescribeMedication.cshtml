@model WARDMANAGEMENTSYSTEM.Models.Prescription
@{
    ViewData["Title"] = "Prescribe Medication";
    ViewData["Breadcrumb"] = "<a href='/Doctor/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Prescribe</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Prescribe Medication</h1><p>@ViewBag.PatientName</p></div>
    <a asp-action="PrescriptionsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>
<div style="max-width:560px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-prescription"></i> Prescription Details</span></div>
        <div class="card-body">
            <form asp-action="PrescribeMedication" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="AdmissionId" type="hidden" />
                <div class="form-group">
                    <label class="form-label" asp-for="MedicationId">Medication</label>
                    <select asp-for="MedicationId" asp-items="ViewBag.Medications" class="form-control"></select>
                    <span asp-validation-for="MedicationId" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Dosage">Dosage</label>
                    <input asp-for="Dosage" class="form-control" placeholder="e.g. 500mg" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Frequency">Frequency</label>
                    <input asp-for="Frequency" class="form-control" placeholder="e.g. Twice daily" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Duration">Duration</label>
                    <input asp-for="Duration" class="form-control" placeholder="e.g. 7 days" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Prescribe</button>
                    <a asp-action="PrescriptionsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}