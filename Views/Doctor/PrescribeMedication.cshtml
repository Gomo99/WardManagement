@model Prescription
@{
    ViewData["Title"] = "Prescribe Medication";
    ViewData["Breadcrumb"] = $"<span class='page-title-bar'>Prescribe Medication for {ViewBag.PatientName}</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1><i class="fa-solid fa-prescription"></i> Prescribe Medication</h1>
        <p>@ViewBag.PatientName</p>
    </div>
    <a asp-action="PatientFolder" asp-route-admissionId="@Model.AdmissionId" class="btn btn-secondary btn-sm">
        <i class="fa-solid fa-arrow-left"></i> Back to Folder
    </a>
</div>

<form asp-action="PrescribeMedication" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AdmissionId" />

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-pills"></i> New Prescription</span></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MedicationId" class="form-label">Medication</label>
                    <select asp-for="MedicationId" class="form-select" asp-items="ViewBag.Medications">
                        <option value="">-- Select Medication --</option>
                    </select>
                    <span asp-validation-for="MedicationId" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Dosage" class="form-label">Dosage</label>
                    <input asp-for="Dosage" class="form-control" placeholder="e.g. 500mg" />
                    <span asp-validation-for="Dosage" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Frequency" class="form-label">Frequency</label>
                    <input asp-for="Frequency" class="form-control" placeholder="e.g. 3x daily" />
                    <span asp-validation-for="Frequency" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="Duration" class="form-label">Duration</label>
                    <input asp-for="Duration" class="form-control" placeholder="e.g. 7 days" />
                    <span asp-validation-for="Duration" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ScriptManagerId" class="form-label">Assign to Script Manager</label>
                    <select asp-for="ScriptManagerId" class="form-select" asp-items="ViewBag.ScriptManagers">
                        <option value="">-- Optional --</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="PrescribedDate" class="form-label">Date</label>
                    <input asp-for="PrescribedDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="PrescribedDate" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes"></textarea>
            </div>

            @* Duplicate override checkbox (visible when error exists) *@
            @if (ViewContext.ModelState["MedicationId"]?.Errors.Any(e => e.ErrorMessage.Contains("Duplicate")) == true)
            {
                <div class="alert alert-warning">
                    <i class="fa-solid fa-triangle-exclamation"></i> Duplicate prescription detected!
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="overrideDuplicate" value="true" id="overrideDuplicate" />
                        <label class="form-check-label" for="overrideDuplicate">
                            I understand, prescribe anyway
                        </label>
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" name="overrideDuplicate" value="false" />
            }

            <div class="text-end">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Prescribe</button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}