@model WARDMANAGEMENTSYSTEM.Models.Admission
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Patient Folder";
    ViewData["Breadcrumb"] = "<a href='/Doctor/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/Doctor/MyPatients'>Patients</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Folder</span>";
    var patient = Model.Patient;
}
<div class="page-header">
    <div class="page-header-title">
        <h1>@patient.FullName</h1>
        <p>Admission #@Model.Id — @Model.Bed?.BedNumberWithWard</p>
    </div>
    <div style="display:flex; gap:8px;">
        <a asp-action="RecordVisit" asp-route-admissionId="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-stethoscope"></i> Record Visit</a>
        <a asp-action="ScheduleVisit" asp-route-admissionId="@Model.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-calendar-plus"></i> Schedule</a>
        <a asp-action="PrescribeMedication" asp-route-admissionId="@Model.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-prescription"></i> Prescribe</a>
        <a asp-action="RecordTreatment" asp-route-admissionId="@Model.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-kit-medical"></i> Treatment</a>
        <a asp-action="PatientInstructions" asp-route-admissionId="@Model.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-clipboard-list"></i> Instructions</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<!-- Sections: Allergies, Conditions, Chronic Meds -->
<div style="margin-bottom:20px;">
    <div class="card" style="margin-bottom:16px;">
        <div class="card-header"><span class="card-title">Medical History</span></div>
        <div class="card-body">
            <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap:12px;">
                <div>
                    <strong>Allergies:</strong>
                    <ul style="margin:4px 0 0 16px;">@foreach (var aa in Model.AdmissionAllergies){
                    <li>@aa.Allergy.Name</li>
                                        }
</ul>
                </div>
                <div>
                    <strong>Chronic Conditions:</strong>
                    <ul style="margin:4px 0 0 16px;">@foreach (var ac in Model.AdmissionConditions){
                    <li>@ac.Condition.Name</li>
                                        }
</ul>
                </div>
                <div>
                    <strong>Chronic Medications:</strong>
                    <ul style="margin:4px 0 0 16px;">@foreach (var am in Model.AdmissionMedications){
                    <li>@am.Medication.Name</li>
                                        }
</ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Vitals -->
    <div class="card" style="margin-bottom:16px;">
        <div class="card-header"><span class="card-title">Recent Vitals</span></div>
        <div class="card-body">
            @if (ViewBag.Vitals == null || ViewBag.Vitals.Count == 0)
            {
                <p class="text-muted">No vitals recorded.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Date</th><th>BP</th><th>Temp (°C)</th><th>Sugar</th><th>HR</th><th>RR</th><th>SpO₂</th></tr></thead>
                        <tbody>
                            @foreach (var v in ViewBag.Vitals)
                            {
                                <tr>
                                    <td>@v.DateRecorded.ToString("g")</td>
                                    <td>@v.BloodPressure</td>
                                    <td>@v.TemperatureCelsius</td>
                                    <td>@v.BloodSugarMmolL</td>
                                    <td>@v.HeartRateBpm</td>
                                    <td>@v.RespiratoryRate</td>
                                    <td>@v.OxygenSaturation</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Treatments, Medications, Visits etc. similar compact tables -->
    <!-- For brevity I'll include placeholders; you can expand as needed -->
</div>

<!-- Discharge form (if active) -->
@if (Model.IsActive == Status.Active)
{
    <div class="card" style="border-color:#F5C6C1;">
        <div class="card-body">
            <h3>Discharge Patient</h3>
            <form asp-action="DischargePatient" method="post">
                <input type="hidden" name="admissionId" value="@Model.Id" />
                <textarea name="dischargeInstructions" class="form-control" rows="2" placeholder="Discharge instructions (optional)"></textarea>
                <button type="submit" class="btn btn-danger btn-sm" style="margin-top:8px;" onclick="return confirm('Discharge this patient?');"><i class="fa-solid fa-right-from-bracket"></i> Discharge</button>
            </form>
        </div>
    </div>
}