@model List<FollowUpAppointment>
@{
    ViewData["Title"] = "Follow‑Up Appointments";
    ViewData["Breadcrumb"] = $"<span class='page-title-bar'>Follow‑Ups for {ViewBag.PatientName}</span>";
}

<div class="page-header">
    <h1><i class="fa-solid fa-list-check"></i> Follow‑Up Appointments</h1>
    <a asp-action="PatientFolder" asp-route-admissionId="@ViewBag.AdmissionId" class="btn btn-secondary btn-sm">
        <i class="fa-solid fa-arrow-left"></i> Back to Folder
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No follow‑up appointments scheduled.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Location</th>
                <th>Assigned Doctor</th>
                <th>Notes</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appt in Model)
            {
                <tr>
                    <td>@appt.AppointmentDate.ToString("ddd, dd MMM yyyy HH:mm")</td>
                    <td>@appt.Location</td>
                    <td>@(appt.AssignedDoctor?.FullName ?? "—")</td>
                    <td>@appt.Notes</td>
                    <td>
                        @if (appt.IsCompleted)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}