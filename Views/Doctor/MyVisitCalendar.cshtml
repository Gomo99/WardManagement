@{
    int month = ViewBag.DisplayMonth;
    int year = ViewBag.DisplayYear;
    var visitsByDate = ViewBag.VisitsByDate as Dictionary<DateTime, List<DoctorVisit>>;

    // First day of the month and total days
    var firstDay = new DateTime(year, month, 1);
    int daysInMonth = DateTime.DaysInMonth(year, month);
    int startDayOfWeek = (int)firstDay.DayOfWeek; // Sunday = 0, Monday = 1, ...

    // Adjust for Monday as first day of week (optional)
    // We'll keep Sunday=0 and display accordingly; you can shift if you prefer Monday start.
    // For simplicity, we display Sunday..Saturday.

    // Previous and next month links
    DateTime prevMonth = firstDay.AddMonths(-1);
    DateTime nextMonth = firstDay.AddMonths(1);

    ViewData["Title"] = $"Visit Calendar – {firstDay:MMMM yyyy}";
    ViewData["Breadcrumb"] = $"<span class='page-title-bar'>Visit Calendar – {firstDay:MMMM yyyy}</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1><i class="fa-solid fa-calendar-days"></i> Visit Calendar</h1>
        <p>Your upcoming scheduled visits</p>
    </div>
    <div>
        <a asp-action="Dashboard" class="btn btn-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Dashboard</a>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="MyVisitCalendar" asp-route-year="@prevMonth.Year" asp-route-month="@prevMonth.Month"
       class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-chevron-left"></i> @prevMonth.ToString("MMM yyyy")
    </a>
    <h4 class="mb-0">@firstDay.ToString("MMMM yyyy")</h4>
    <a asp-action="MyVisitCalendar" asp-route-year="@nextMonth.Year" asp-route-month="@nextMonth.Month"
       class="btn btn-outline-secondary btn-sm">
        @nextMonth.ToString("MMM yyyy") <i class="fa-solid fa-chevron-right"></i>
    </a>
</div>

<table class="table table-bordered calendar-table">
    <thead>
        <tr>
            <th class="text-center">Sun</th>
            <th class="text-center">Mon</th>
            <th class="text-center">Tue</th>
            <th class="text-center">Wed</th>
            <th class="text-center">Thu</th>
            <th class="text-center">Fri</th>
            <th class="text-center">Sat</th>
        </tr>
    </thead>
    <tbody>
        @{
            int day = 1;
            // Loop weeks
            for (int week = 0; week < 6; week++)
            {
                <tr>
                    @for (int dow = 0; dow < 7; dow++)
                    {
                        if ((week == 0 && dow < startDayOfWeek) || day > daysInMonth)
                        {
                            <td class="text-muted" style="height:100px;"></td>
                        }
                        else
                        {
                            var currentDate = new DateTime(year, month, day);
                            bool hasVisits = visitsByDate != null && visitsByDate.ContainsKey(currentDate);
                            <td style="height:100px; vertical-align:top; @(hasVisits ? "background-color:#eaf7fa;" : "")">
                                <div class="fw-bold">@day</div>
                                @if (hasVisits)
                                {
                                    var dayVisits = visitsByDate[currentDate];
                                    foreach (var dv in dayVisits)
                                    {
                                        string patientName = dv.Admission?.Patient?.FullName ?? "Unknown";
                                        string time = dv.VisitDate.ToString("HH:mm");
                                        <div class="small">
                                            <a asp-action="PatientFolder" asp-route-admissionId="@dv.AdmissionId"
                                               title="@patientName at @time">
                                                @patientName (@time)
                                            </a>
                                        </div>
                                    }
                                }
                            </td>
                            day++;
                        }
                    }
                </tr>
                if (day > daysInMonth) break;
            }
        }
    </tbody>
</table>

@section Styles {
    <style>
        .calendar-table td, .calendar-table th {
            width: 14.28%;
        }

            .calendar-table td:hover {
                background-color: #f0f0f0 !important;
            }
    </style>
}