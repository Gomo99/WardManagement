@model WARDMANAGEMENTSYSTEM.Models.Treatment
@{
    ViewData["Title"] = "Record Treatment";
    ViewData["Breadcrumb"] = "<a href='/Doctor/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Record Treatment</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Record Treatment</h1><p>@ViewBag.PatientName</p></div>
    <a asp-action="TreatmentsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>
<div style="max-width:560px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-kit-medical"></i> Treatment Details</span></div>
        <div class="card-body">
            <form asp-action="RecordTreatment" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="AdmissionId" type="hidden" />
                <div class="form-group">
                    <label class="form-label" asp-for="TreatmentType">Treatment Type</label>
                    <input asp-for="TreatmentType" class="form-control" placeholder="e.g. IV Drip, Catheter" />
                    <span asp-validation-for="TreatmentType" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="TreatmentDate">Date</label>
                    <input asp-for="TreatmentDate" class="form-control" type="datetime-local" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    <a asp-action="TreatmentsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}