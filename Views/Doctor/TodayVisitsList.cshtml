@model List<WARDMANAGEMENTSYSTEM.Models.DoctorVisit>

@{
    ViewData["Title"] = ViewBag.Title ?? "Today's Visits";
    ViewData["Breadcrumb"] = $"<span class='page-title-bar'>{ViewBag.Title}</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>@ViewBag.Title</h1>
        <p>@ViewBag.Subtitle</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No visits scheduled for today.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Bed / Ward</th>
                <th>Visit Time</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var visit in Model)
            {
                <tr>
                    <td>@visit.Admission?.Patient?.FullName</td>
                    <td>@visit.Admission?.Bed?.BedNumber (@visit.Admission?.Bed?.Ward?.Name)</td>
                    <td>@visit.VisitDate.ToString("HH:mm")</td>
                    <td>@(string.IsNullOrEmpty(visit.Instructions) ? "-" : visit.Instructions)</td>
                    <td>
                        <a asp-action="PatientFolder" asp-route-admissionId="@visit.AdmissionId" class="btn btn-outline-primary btn-sm">
                            <i class="fa-solid fa-folder-open"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}