@model WARDMANAGEMENTSYSTEM.Models.ConsumableOrder
@{
    ViewData["Title"] = "Request Consumable";
    ViewData["Breadcrumb"] = "<a href='/ConsumablesManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/ConsumablesManager/Orders'>Orders</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>New Request</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Request Consumable</h1>
        <p>Order stock from the hospital store</p>
    </div>
    <a asp-action="Orders" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-truck-ramp-box" style="color:var(--teal); margin-right:8px;"></i>Order Details</span>
        </div>
        <div class="card-body">
            <form asp-action="RequestConsumable" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" asp-for="ConsumableId">Consumable <span class="required">*</span></label>
                    <select asp-for="ConsumableId" asp-items="ViewBag.Consumables" class="form-control">
                        <option value="">Select a consumable</option>
                    </select>
                    <span asp-validation-for="ConsumableId" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="QuantityRequested">Quantity <span class="required">*</span></label>
                    <input asp-for="QuantityRequested" class="form-control" type="number" min="1" value="1" />
                    <span asp-validation-for="QuantityRequested" class="field-validation-error"></span>
                </div>

                <div class="form-check">
                    <input asp-for="IsUrgent" class="form-check-input" />
                    <label asp-for="IsUrgent" class="form-check-label">Mark as urgent</label>
                </div>

                <div class="mb-3">
                    <label asp-for="Reason" class="form-label">Reason for Request</label>
                    <input asp-for="Reason" class="form-control" placeholder="e.g. Low Stock, Par Stock Refill, New Item" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>


                <div style="display:flex; gap:12px; margin-top:4px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Place Order</button>
                    <a asp-action="Orders" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}