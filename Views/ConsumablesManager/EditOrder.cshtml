@model WARDMANAGEMENTSYSTEM.Models.ConsumableOrder
@{
    ViewData["Title"] = "Edit Order";
    ViewData["Breadcrumb"] = "<a href='/ConsumablesManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/ConsumablesManager/Orders'>Orders</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Edit Order</h1>
        <p>Order #@Model.Id — @Model.Consumable?.Name</p>
    </div>
    <a asp-action="Orders" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-pen-to-square" style="color:var(--teal); margin-right:8px;"></i>Edit Order Details</span>
        </div>
        <div class="card-body">
            <form asp-action="EditOrder" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div class="form-group">
                    <label class="form-label" asp-for="ConsumableId">Consumable</label>
                    <select asp-for="ConsumableId" asp-items="ViewBag.Consumables" class="form-control"></select>
                    <span asp-validation-for="ConsumableId" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="QuantityRequested">Quantity <span class="required">*</span></label>
                    <input asp-for="QuantityRequested" class="form-control" type="number" min="1" />
                    <span asp-validation-for="QuantityRequested" class="field-validation-error"></span>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
                    <a asp-action="Orders" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}