@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.Consumable>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Consumables";
    ViewData["Breadcrumb"] = "<a href='/ConsumablesManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Consumables</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Consumables</h1>
        <p>@Model.Count() item(s) registered</p>
    </div>
    <a asp-action="CreateConsumable" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Add Consumable
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]</div>
}

<!-- STATUS FILTER -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-body" style="padding:14px 20px;">
        <form method="get" asp-action="Consumables" style="display:flex; gap:10px; align-items:flex-end;">
            <div>
                <label class="form-label" style="margin-bottom:5px;">Status</label>
                <select name="status" asp-items="ViewBag.Statuses" class="form-control" style="width:130px;"></select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="fa-solid fa-filter"></i> Apply</button>
            <a asp-action="Consumables" class="btn btn-outline btn-sm"><i class="fa-solid fa-xmark"></i> Clear</a>
        </form>
    </div>
</div>

<!-- Stock level summary -->
@{
    int sufficient = Model.Count(c => c.QuantityOnHand > c.ReorderLevel);
    int low = Model.Count(c => c.QuantityOnHand > 0 && c.QuantityOnHand <= c.ReorderLevel);
    int outOfStock = Model.Count(c => c.QuantityOnHand == 0);
}
<div class="d-flex gap-3 mb-3 flex-wrap">
    <span class="badge fs-6" style="background-color:#d4edda; color:#155724;">
        🟢 @sufficient Sufficient
    </span>
    <span class="badge fs-6" style="background-color:#fff3cd; color:#856404;">
        🟡 @low Low
    </span>
    <span class="badge fs-6" style="background-color:#f8d7da; color:#721c24;">
        🔴 @outOfStock Out of Stock
    </span>
</div>

<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px; color:var(--gray-400);">
            <i class="fa-solid fa-box-open" style="font-size:2.5rem; margin-bottom:12px; display:block; color:var(--gray-200);"></i>
            <div style="font-weight:600; color:var(--navy); margin-bottom:4px;">No consumables found</div>
            <a asp-action="CreateConsumable" class="btn btn-primary btn-sm" style="margin-top:12px;">Add First Consumable</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Stock Level</th>
                        <th>Reorder Level</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cons in Model)
                    {
                        // Determine stock level and row class
                        string stockClass;
                        string dotColor;
                        if (cons.QuantityOnHand == 0)
                        {
                            stockClass = "table-danger";
                            dotColor = "var(--danger)";
                        }
                        else if (cons.QuantityOnHand <= cons.ReorderLevel)
                        {
                            stockClass = "table-warning";
                            dotColor = "var(--warning)";
                        }
                        else
                        {
                            stockClass = "";
                            dotColor = "var(--success)";
                        }

                        <tr class="@stockClass">
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:32px; height:32px; border-radius:8px; background:var(--teal-lt); color:var(--teal); display:flex; align-items:center; justify-content:center; font-size:.85rem;">
                                        <i class="fa-solid fa-box-open"></i>
                                    </div>
                                    <span style="font-weight:600; color:var(--navy);">@cons.Name</span>
                                </div>
                            </td>
                            <td>
                                <span style="display:inline-flex; align-items:center; gap:6px;">
                                    <span style="width:10px; height:10px; border-radius:50%; background:@dotColor; display:inline-block;"></span>
                                    @cons.QuantityOnHand on hand
                                </span>
                            </td>
                            <td>@cons.ReorderLevel</td>
                            <td>
                                @if (cons.IsActive == Status.Active)
                                {
                                    <span class="badge badge-success"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex; gap:6px; justify-content:flex-end;">
                                    <a asp-action="DetailsConsumable" asp-route-id="@cons.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="EditConsumable" asp-route-id="@cons.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i></a>
                                    @if (cons.IsActive == Status.Active)
                                    {
                                        <form asp-action="DeleteConsumable" asp-route-id="@cons.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger); border-color:var(--danger);"
                                                    onclick="return confirm('Deactivate @cons.Name?')">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="RestoreConsumable" asp-route-id="@cons.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--success); border-color:var(--success);">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    }
                                    <a asp-action="AdjustStock" asp-route-id="@cons.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen-to-square"></i> Adjust Stock</a>
                                    <a href="@Url.Action("DetailsConsumable", new { id = cons.Id })" title="View Details">
                                        <i class="fa-solid fa-qrcode" style="color: #2980b9; margin-left: 8px;"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Styles {
    <style>
        /* Bootstrap-like table row colours (if not already globally available) */
        .table-danger {
            background-color: #f8d7da !important;
        }

        .table-warning {
            background-color: #fff3cd !important;
        }
    </style>
}