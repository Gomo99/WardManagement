@model WARDMANAGEMENTSYSTEM.Models.Consumable
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Consumable Details";
    ViewData["Breadcrumb"] = "<a href='/ConsumablesManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/ConsumablesManager/Consumables'>Consumables</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Details</span>";
    var isActive = Model.IsActive == Status.Active;
}

<div class="page-header">
    <div class="page-header-title">
        <h1>@Model.Name</h1>
        <p>Consumable ID #@Model.Id</p>
    </div>
    <div style="display:flex; gap:8px;">
        <a asp-action="EditConsumable" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen"></i> Edit</a>
        <a asp-action="Consumables" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
    </div>
</div>

<div style="max-width:500px; display:flex; flex-direction:column; gap:16px;">
    <div class="card">
        <div class="card-body">
            <div style="display:flex; align-items:center; gap:16px; margin-bottom:20px;">
                <div style="width:52px; height:52px; border-radius:12px; background:var(--teal-lt); color:var(--teal); display:flex; align-items:center; justify-content:center; font-size:1.3rem;">
                    <i class="fa-solid fa-box-open"></i>
                </div>
                <div>
                    <h2 style="font-family:var(--font-serif); font-size:1.3rem; color:var(--navy); margin-bottom:4px;">@Model.Name</h2>
                    <span class="badge @(isActive ? "badge-success" : "badge-danger")">
                        <span class="badge-dot"></span> @Model.IsActive
                    </span>
                </div>
            </div>
            <div style="background:var(--gray-50); border-radius:8px; padding:14px;">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; font-size:.875rem;">
                    <div>
                        <div style="font-size:.72rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px;">Quantity On Hand</div>
                        <div style="font-weight:500; color:var(--navy);">@Model.QuantityOnHand</div>
                    </div>
                    <div>
                        <div style="font-size:.72rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px;">Reorder Level</div>
                        <div style="font-weight:500; color:var(--navy);">@Model.ReorderLevel</div>
                    </div>
                    <div style="grid-column:1/-1;">
                        <div style="font-size:.72rem; color:var(--gray-400); text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px;">Description</div>
                        <div style="font-weight:500; color:var(--navy);">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="border-color:@(isActive ? "#F5C6C1" : "#A7E8C8");">
        <div class="card-body" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
            <div>
                <div style="font-weight:600; color:var(--gray-700); margin-bottom:2px;">Status: @Model.IsActive</div>
            </div>
            @if (isActive)
            {
                <form asp-action="DeleteConsumable" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Deactivate @Model.Name?')">
                        <i class="fa-solid fa-ban"></i> Deactivate
                    </button>
                </form>
            }
            else
            {
                <form asp-action="RestoreConsumable" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm" style="background:var(--success); color:#fff;">
                        <i class="fa-solid fa-rotate-left"></i> Reactivate
                    </button>
                </form>
            }
        </div>
    </div>
</div>