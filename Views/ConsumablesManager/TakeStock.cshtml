@model WARDMANAGEMENTSYSTEM.Models.StockTake
@{
    ViewData["Title"] = "Start Stock Take";
    ViewData["Breadcrumb"] = "<a href='/ConsumablesManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/ConsumablesManager/StockTakes'>Stock Takes</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>New Count</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Start Stock Take</h1>
        <p>Begin a physical count of ward consumables</p>
    </div>
    <a asp-action="StockTakes" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-calendar-plus" style="color:var(--teal); margin-right:8px;"></i>Stock Take Details</span>
        </div>
        <div class="card-body">
            <form asp-action="StartStockTake" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" asp-for="DateTaken">Date of Count <span class="required">*</span></label>
                    <input asp-for="DateTaken" class="form-control" type="date" />
                    <span asp-validation-for="DateTaken" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes (optional)</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" placeholder="e.g. Weekly count"></textarea>
                </div>
                <div style="display:flex; gap:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-play"></i> Start Counting</button>
                    <a asp-action="StockTakes" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}