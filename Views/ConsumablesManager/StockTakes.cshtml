@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.StockTake>
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Stock Takes";
    ViewData["Breadcrumb"] = "<a href='/ConsumablesManager/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Stock Takes</span>";
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Stock Takes</h1>
        <p>@Model.Count() stock count(s) recorded</p>
    </div>
    <a asp-action="TakeStock" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> New Stock Take
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<div class="card">
    @if (!Model.Any())
    {
        <div style="text-align:center; padding:56px 24px; color:var(--gray-400);">
            <i class="fa-solid fa-clipboard-check" style="font-size:2.5rem; margin-bottom:12px; display:block; color:var(--gray-200);"></i>
            <div style="font-weight:600; color:var(--navy); margin-bottom:4px;">No stock takes yet</div>
            <a asp-action="TakeStock" class="btn btn-primary btn-sm" style="margin-top:12px;">Start First Stock Take</a>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Date Taken</th>
                        <th>Items Counted</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var st in Model)
                    {
                        <tr>
                            <td>@st.DateTaken.ToString("dd MMMM yyyy")</td>
                            <td>@(st.StockTakeItems?.Count ?? 0) items</td>
                            <td>
                                @if (st.IsActive == Status.Active)
                                {
                                    <span class="badge badge-success"><span class="badge-dot"></span> Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><span class="badge-dot"></span> Inactive</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex; gap:6px; justify-content:flex-end;">
                                    <a asp-action="StockTakeDetails" asp-route-id="@st.Id" class="btn btn-outline btn-sm"><i class="fa-solid fa-eye"></i></a>
                                    @if (st.IsActive == Status.Active)
                                    {
                                        <form asp-action="DeleteStockTake" asp-route-id="@st.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline btn-sm" style="color:var(--danger); border-color:var(--danger);"
                                                    onclick="return confirm('Deactivate this stock take?')">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>

                            <a asp-action="VarianceReport" asp-route-stockTakeId="@st.Id" class="btn btn-sm btn-outline-info">
                                <i class="fa-solid fa-chart-simple"></i> Variance
                            </a>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>