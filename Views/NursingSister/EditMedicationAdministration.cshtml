@model WARDMANAGEMENTSYSTEM.Models.MedicationAdministration
@{
    ViewData["Title"] = "Edit Medication Administration";
    ViewData["Breadcrumb"] = "<a href='/NursingSister/Dashboard'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <a href='/NursingSister/Patients'>Patients</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Edit Administration</span>";
}
<div class="page-header">
    <div class="page-header-title"><h1>Edit Administration</h1><p>@ViewBag.PatientName</p></div>
    <a asp-action="MedicationAdministrationsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline btn-sm"><i class="fa-solid fa-arrow-left"></i> Back</a>
</div>

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa-solid fa-pen-to-square"></i> Edit Medication Administration</span></div>
        <div class="card-body">
            <form asp-action="EditMedicationAdministration" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="AdmissionId" type="hidden" />

                <div class="form-group">
                    <label class="form-label" asp-for="MedicationId">Medication</label>
                    <select asp-for="MedicationId" asp-items="ViewBag.Medications" class="form-control">
                    </select>
                    <span asp-validation-for="MedicationId" class="field-validation-error"></span>
                    <small class="form-text text-muted">All medications are available to the Nursing Sister.</small>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Dosage">Dosage</label>
                    <input asp-for="Dosage" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="DateAdministered">Date &amp; Time</label>
                    <input asp-for="DateAdministered" class="form-control" type="datetime-local" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>

                <div style="display:flex; gap:12px; margin-top:12px;">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    <a asp-action="MedicationAdministrationsByAdmission" asp-route-admissionId="@Model.AdmissionId" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}