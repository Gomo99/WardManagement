@model IEnumerable<WARDMANAGEMENTSYSTEM.Models.Notification>
@using System.Security.Claims
@{
    ViewData["Title"] = "Notifications";

    // Determine the dashboard link based on the user's role
    var role = User.FindFirstValue(ClaimTypes.Role);
    string dashboardLink = Url.Action("Index", "Home"); // fallback

    if (!string.IsNullOrEmpty(role))
    {
        switch (role.ToLower())
        {
            case "administrator":
            case "wardadmin":
                dashboardLink = Url.Action("Dashboard", "Admin");
                break;
            case "doctor":
                dashboardLink = Url.Action("Dashboard", "Doctor");
                break;
            case "nurse":
                dashboardLink = Url.Action("Dashboard", "Nurse");
                break;
            case "nursingsister":
                dashboardLink = Url.Action("Dashboard", "NursingSister");
                break;
            case "patient":
                dashboardLink = Url.Action("Dashboard", "Patient");
                break;
            default:
                dashboardLink = Url.Action("Index", "Home");
                break;
        }
    }

    ViewData["Breadcrumb"] = $"<a href='{dashboardLink}'>Dashboard</a> <span class='breadcrumb-sep'>/</span> <span class='page-title-bar'>Notifications</span>";

    int unreadCount = Model.Count(n => !n.IsRead);
    int totalCount = Model.Count();
}

<div class="page-header">
    <div class="page-header-title">
        <h1>Notifications</h1>
        <p>All recent alerts and messages</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa-solid fa-bell"></i> Notifications</span>
        <div style="display:flex; gap:8px;">
            @if (unreadCount > 0)
            {
                <form asp-action="MarkAllRead" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="fa-solid fa-check-double"></i> Mark All Read (@unreadCount)
                    </button>
                </form>
            }
            @if (totalCount > 0)
            {
                <form asp-action="ClearAll" method="post" style="display:inline;" onsubmit="return confirm('Remove all notifications?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline" style="color:var(--danger);">
                        <i class="fa-solid fa-trash-can"></i> Clear All
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar" style="padding: 16px 24px; border-bottom: 1px solid var(--gray-100); display: flex; flex-wrap: wrap; gap: 16px; align-items: center;">
        <div>
            <label for="statusFilter" class="form-label" style="margin-bottom:0;">Status</label>
            <select id="statusFilter" class="form-control" style="width:auto;">
                <option value="all">All</option>
                <option value="unread">Unread</option>
                <option value="read">Read</option>
            </select>
        </div>
        <div>
            <label for="searchInput" class="form-label" style="margin-bottom:0;">Search</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Keyword..." style="width:200px;">
        </div>
        <div>
            <label for="startDate" class="form-label" style="margin-bottom:0;">From</label>
            <input type="date" id="startDate" class="form-control" style="width:auto;">
        </div>
        <div>
            <label for="endDate" class="form-label" style="margin-bottom:0;">To</label>
            <input type="date" id="endDate" class="form-control" style="width:auto;">
        </div>
        <div>
            <label for="pageSizeSelect" class="form-label" style="margin-bottom:0;">Show</label>
            <select id="pageSizeSelect" class="form-control" style="width:auto;">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </div>
        <div style="display:flex; gap:8px; margin-left:auto; align-items:center;">
            <button id="prevPageBtn" class="btn btn-sm btn-outline" disabled><i class="fa-solid fa-chevron-left"></i></button>
            <span id="pageInfo" style="font-size:.875rem; color:var(--gray-700);"></span>
            <button id="nextPageBtn" class="btn btn-sm btn-outline" disabled><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>

    <!-- NOTIFICATION TABLE -->
    @if (!Model.Any())
    {
        <div class="card-body text-center text-muted" style="padding:40px;">
            <i class="fa-solid fa-bell-slash" style="font-size:2rem; display:block; margin-bottom:12px;"></i>
            No notifications yet.
        </div>
    }
    else
    {
        <div class="table-wrap" id="notificationTableContainer">
            <table>
                <thead>
                    <tr>
                        <th>Message</th>
                        <th>Date</th>
                        <th style="width:160px;">Status</th>
                    </tr>
                </thead>
                <tbody id="notificationTableBody">
                    <!-- Rendered by JS -->
                </tbody>
            </table>
        </div>
    }
</div>

@section Styles {
    <style>
        .unread-row {
            background: #F0F7FF;
            font-weight: 500;
        }

        .filter-bar .form-control {
            padding: 6px 10px;
            font-size: .82rem;
        }
    </style>
}

@section Scripts {
    <script>
        // ── RELATIVE TIME HELPER ──────────────────────
        function timeAgo(isoString) {
            if (!isoString) return '';
            const now = new Date();
            const then = new Date(isoString);
            const seconds = Math.floor((now - then) / 1000);
            let interval = Math.floor(seconds / 31536000);
            if (interval > 1) return interval + ' years ago';
            interval = Math.floor(seconds / 2592000);
            if (interval > 1) return interval + ' months ago';
            interval = Math.floor(seconds / 86400);
            if (interval > 1) return interval + ' days ago';
            if (interval === 1) return 'yesterday';
            interval = Math.floor(seconds / 3600);
            if (interval > 1) return interval + ' hours ago';
            if (interval === 1) return '1 hour ago';
            interval = Math.floor(seconds / 60);
            if (interval > 1) return interval + ' minutes ago';
            if (interval === 1) return '1 minute ago';
            return 'just now';
        }

        // Embed the full notification list as JSON
        const allNotifications = @Json.Serialize(Model);

        // State
        let currentPage = 1;
        let pageSize = 10;
        let filteredData = [...allNotifications];

        // DOM elements
        const tbody = document.getElementById('notificationTableBody');
        const statusFilter = document.getElementById('statusFilter');
        const searchInput = document.getElementById('searchInput');
        const startDateInput = document.getElementById('startDate');
        const endDateInput = document.getElementById('endDate');
        const pageSizeSelect = document.getElementById('pageSizeSelect');
        const prevBtn = document.getElementById('prevPageBtn');
        const nextBtn = document.getElementById('nextPageBtn');
        const pageInfo = document.getElementById('pageInfo');

        // Helper: extract date part (YYYY-MM-DD) from ISO string
        function getDateOnly(isoString) {
            return isoString ? isoString.split('T')[0] : null;
        }

        // Filtering logic
        function applyFilters() {
            const statusVal = statusFilter.value;
            const keyword = searchInput.value.toLowerCase().trim();
            const startDate = startDateInput.value;
            const endDate = endDateInput.value;

            filteredData = allNotifications.filter(n => {
                if (statusVal === 'unread' && n.isRead) return false;
                if (statusVal === 'read' && !n.isRead) return false;
                if (keyword && !n.message.toLowerCase().includes(keyword)) return false;
                const notifDate = getDateOnly(n.createdAt);
                if (startDate && notifDate < startDate) return false;
                if (endDate && notifDate > endDate) return false;
                return true;
            });

            currentPage = 1;
            renderTable();
        }

        // Render current page
        function renderTable() {
            const totalPages = Math.ceil(filteredData.length / pageSize) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            const startIdx = (currentPage - 1) * pageSize;
            const pageData = filteredData.slice(startIdx, startIdx + pageSize);

            let html = '';
            if (pageData.length === 0) {
                html = `<tr><td colspan="3" class="text-center text-muted" style="padding:40px;">No matching notifications</td></tr>`;
            } else {
                pageData.forEach(n => {
                    const rowClass = n.isRead ? '' : 'unread-row';
                    const dateStr = timeAgo(n.createdAt);   // ← relative time
                    const messageHtml = n.link ? `<a href="${n.link}">${escapeHtml(n.message)}</a>` : escapeHtml(n.message);
                    const statusHtml = n.isRead
                        ? `<span class="badge badge-teal" style="margin-right:8px;">Read</span>`
                        : `<form action="/Notification/MarkRead" method="post" style="display:inline;">
                               @Html.AntiForgeryToken()
                               <input type="hidden" name="id" value="${n.id}" />
                               <button type="submit" class="btn btn-sm btn-outline">Read</button>
                           </form>`;
                    const deleteForm = `<form action="/Notification/Delete" method="post" style="display:inline;" onsubmit="return confirm('Remove this notification?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="${n.id}" />
                                            <button type="submit" class="btn btn-sm btn-outline" style="color:var(--danger);"><i class="fa-solid fa-xmark"></i></button>
                                        </form>`;

                    html += `
                        <tr class="${rowClass}">
                            <td>${messageHtml}</td>
                            <td><small>${dateStr}</small></td>
                            <td style="text-align:right;">
                                ${statusHtml}
                                ${deleteForm}
                            </td>
                        </tr>
                    `;
                });
            }

            tbody.innerHTML = html;
            updatePagination(totalPages);
        }

        function updatePagination(totalPages) {
            pageInfo.textContent = `Page ${currentPage} of ${totalPages} (${filteredData.length} items)`;
            prevBtn.disabled = currentPage <= 1;
            nextBtn.disabled = currentPage >= totalPages;
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Event listeners
        statusFilter.addEventListener('change', applyFilters);
        searchInput.addEventListener('input', applyFilters);
        startDateInput.addEventListener('change', applyFilters);
        endDateInput.addEventListener('change', applyFilters);
        pageSizeSelect.addEventListener('change', function() {
            pageSize = parseInt(this.value);
            applyFilters();
        });

        prevBtn.addEventListener('click', function() {
            if (currentPage > 1) {
                currentPage--;
                renderTable();
            }
        });

        nextBtn.addEventListener('click', function() {
            const totalPages = Math.ceil(filteredData.length / pageSize);
            if (currentPage < totalPages) {
                currentPage++;
                renderTable();
            }
        });

        // Initial render
        applyFilters();
    </script>
}