@{
    int unread = ViewBag.UnreadCount ?? 0;
}

<div class="nav-notification">
    <a href="javascript:void(0)"
       class="topbar-btn notification-bell"
       id="notificationBell"
       data-tooltip="Notifications">
        <i class="fa-solid fa-bell"></i>
        @if (unread > 0)
        {
            <span class="badge badge-danger notification-count">@unread</span>
        }
    </a>

    <div class="notification-dropdown"
         id="notificationDropdown"
         style="display:none;">
        <div class="notification-dropdown-header">
            <strong>Notifications</strong>
            <a asp-controller="Notification" asp-action="Index">View All</a>
        </div>
        <div class="notification-list" id="notificationList">
            <div style="padding:10px; text-align:center;">Loading...</div>
        </div>
    </div>
</div>