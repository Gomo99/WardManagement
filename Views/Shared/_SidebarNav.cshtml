@using WARDMANAGEMENTSYSTEM.Models
@{
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var current = ViewContext.RouteData.Values["controller"]?.ToString() + "/" + ViewContext.RouteData.Values["action"]?.ToString();
    string Active(string ctrl, string act = "") {
        var c = ViewContext.RouteData.Values["controller"]?.ToString();
        var a = ViewContext.RouteData.Values["action"]?.ToString();
        return (c == ctrl && (act == "" || a == act)) ? "active" : "";
    }
}

