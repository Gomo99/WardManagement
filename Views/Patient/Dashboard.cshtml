@model WARDMANAGEMENTSYSTEM.Models.Patient
@using WARDMANAGEMENTSYSTEM.AppStatus
@{
    ViewData["Title"] = "Patient Dashboard";
    ViewData["Breadcrumb"] = "<span class='page-title-bar'>Dashboard</span>";
    var activeAdmission = ViewBag.ActiveAdmission as Admission;
}
<div class="page-header">
    <div class="page-header-title">
        <h1>Welcome, @Model.FirstName</h1>
        <p>Patient #@Model.Id</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]</div>
}

<!-- Quick summary cards -->
<div class="stat-grid" style="margin-bottom:32px;">
    <div class="stat-card">
        <div class="stat-icon teal"><i class="fa-solid fa-bed-pulse"></i></div>
        <div>
            <div class="stat-value">@((activeAdmission != null) ? "Currently Admitted" : "Not Admitted")</div>
            <div class="stat-label">Admission Status</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon navy"><i class="fa-solid fa-hospital"></i></div>
        <div>
            <div class="stat-value">@ViewBag.TotalAdmissions</div>
            <div class="stat-label">Total Admissions</div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-user"></i> My Profile</span>
        </div>
        <div class="card-body">
            <p style="font-size:.82rem; color:var(--gray-400); margin-bottom:16px;">View and update your personal details.</p>
            <div style="display:flex; gap:8px;">
                <a asp-action="MyProfile" class="btn btn-primary btn-sm"><i class="fa-solid fa-eye"></i> View Profile</a>
                <a asp-action="EditMyProfile" class="btn btn-outline btn-sm"><i class="fa-solid fa-pen"></i> Edit</a>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa-solid fa-calendar-check"></i> Admissions</span>
        </div>
        <div class="card-body">
            <p style="font-size:.82rem; color:var(--gray-400); margin-bottom:16px;">Review your hospital stays.</p>
            <a asp-action="MyAdmissions" class="btn btn-primary btn-sm"><i class="fa-solid fa-list"></i> View Admissions</a>
        </div>
    </div>

    @if (activeAdmission != null)
    {
        <div class="card">
            <div class="card-header">
                <span class="card-title"><i class="fa-solid fa-folder-open"></i> Current Stay</span>
            </div>
            <div class="card-body">
                <p style="font-size:.82rem; color:var(--gray-400); margin-bottom:4px;">Bed: @activeAdmission.Bed?.BedNumberWithWard</p>
                <p style="font-size:.82rem; color:var(--gray-400); margin-bottom:16px;">Doctor: @activeAdmission.Doctor?.FullName</p>
                <a asp-action="MyPatientFolder" asp-route-admissionId="@activeAdmission.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-folder"></i> Open Folder</a>
            </div>
        </div>
    }
</div>

<div style="margin-top:32px;">
    <div class="card" style="border-color:#F5C6C1;">
        <div class="card-body" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
            <div>
                <div style="font-weight:600; color:var(--gray-700);">Deactivate Account</div>
                <p style="font-size:.82rem; color:var(--gray-400);">This will disable your login and cannot be undone without staff assistance.</p>
            </div>
            <form asp-action="DeactivateMyAccount" method="post" onsubmit="return confirm('Deactivate your account? This will log you out immediately.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-ban"></i> Deactivate</button>
            </form>
        </div>
    </div>
</div>